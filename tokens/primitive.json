      "600": "#15d26b",
      "700": "#0b9f55"
    },
    "warning": {
      "50": "#fff0fb",
      "100": "#ffd5f5",
      "500": "#ff4dd8",
      "600": "#e11cad",
      "700": "#b31286"
    },
    "danger": {
      "50": "#fff1f5",
      "100": "#ffd7e3",
      "500": "#ff4d7d",
      "600": "#ff1f56",
      "700": "#c1124d"
