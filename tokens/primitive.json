    "info": {
      "50": "#eefbff",
      "100": "#ccf5ff",
      "500": "#33cfff",
      "600": "#0099ff",
      "700": "#005fd6"
    },
    "savings": {
      "50": "#f5ffe6",
      "100": "#e3ffbf",
      "500": "#c8ff3d",
      "600": "#a5e600",
      "700": "#6ea600"
