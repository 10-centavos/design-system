      "600": "#ff8a00",
      "700": "#cc6d00"
    }
  },
  "spacing": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem"
  },
  "radius": {
    "none": "0",
    "sm": "0.25rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "full": "9999px"
  },
  "shadow": {
    "none": "none",
    "sm": "0 1px 2px rgb(15 23 42 / 0.10), 0 0 0 1px rgb(6 182 212 / 0.06)",
    "md": "0 14px 34px rgb(15 23 42 / 0.16), 0 0 0 1px rgb(14 165 233 / 0.10), 0 0 28px rgb(6 182 212 / 0.12)"
  },
  "font": {
    "family": {
      "sans": "Inter, ui-sans-serif, system-ui, sans-serif",
      "numeric": "Inter, ui-sans-serif, system-ui, sans-serif"
    },
    "size": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem"
    },
    "weight": {
      "regular": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    },
    "lineHeight": {
      "tight": "1.2",
      "normal": "1.5"
    }
  },
  "breakpoint": {
    "sm": "40rem",
    "md": "48rem",
    "lg": "64rem",
    "xl": "80rem"
  },
  "motion": {
    "duration": {
      "fast": "120ms",
      "normal": "180ms",
      "slow": "240ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "emphasized": "cubic-bezier(0.2, 0, 0, 1.2)"
    }
